# EMA Cloud Sector Scanner — Environment Variables
# Copy to .env and fill in your values.
# .env is loaded automatically by docker-compose and by `just` (via dotenv-load).

# ── Scanner behaviour ──────────────────────────────────────────────────────────
# Trading style: scalping | intraday | swing | position | long_term
EMA_SCANNER_TRADING_STYLE=intraday

# Scan interval in seconds (default: 60)
EMA_SCANNER_SCAN_INTERVAL=60

# Respect US market hours? (true = market hours only, false = run 24/7)
EMA_SCANNER_MARKET_HOURS_ONLY=true

# Scan individual stocks within each ETF's top holdings? (true/false, default: false)
EMA_SCANNER_SCAN_HOLDINGS=false

# Number of top holdings to scan per ETF (default: 10)
EMA_SCANNER_HOLDINGS_COUNT=10

# Max concurrent stock scans per ETF (default: 5)
EMA_SCANNER_HOLDINGS_CONCURRENT=5

# ── Data provider ──────────────────────────────────────────────────────────────
# Options: yahoo (free, default) | alpaca | polygon
EMA_DATA_PROVIDER=yahoo

# Alpaca — required when EMA_DATA_PROVIDER=alpaca
# Get keys at https://alpaca.markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Polygon.io — required when EMA_DATA_PROVIDER=polygon
# Get a key at https://polygon.io
POLYGON_API_KEY=

# ── Alerts — Telegram ─────────────────────────────────────────────────────────
# 1. Create a bot via @BotFather and copy the token
# 2. Get your chat ID from @userinfobot or the Telegram API
# Both must be set for Telegram alerts to activate automatically
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Alerts — Discord ──────────────────────────────────────────────────────────
# Create a webhook in your Discord server: Channel Settings → Integrations → Webhooks
# Setting this URL enables Discord alerts automatically
DISCORD_WEBHOOK_URL=

# ── Alerts — Email (SMTP) ─────────────────────────────────────────────────────
# Gmail example: smtp.gmail.com / port 587 / use an App Password (not your login password)
# Outlook example: smtp-mail.outlook.com / port 587
SMTP_SERVER=smtp.gmail.com
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=
